---
import Layout from '../layouts/Layout.astro';

const menu = {
  appetizers: [
    { name: 'Samosa', description: 'Crispy pastry filled with spiced potatoes and peas', price: '$4.99' },
    { name: 'Pakora', description: 'Vegetable fritters fried until golden and crispy', price: '$5.99' },
    { name: 'Chicken Tikka', description: 'Marinated chicken cooked in a tandoor oven', price: '$7.99' },
    { name: 'Paneer Tikka', description: 'Cubes of paneer cheese marinated and tandoori grilled', price: '$7.99' },
  ],
  mainCourses: [
    { name: 'Butter Chicken', description: 'Tender chicken in a creamy tomato sauce with fenugreek', price: '$15.99' },
    { name: 'Tikka Masala (Chicken)', description: 'Tandoori chicken in a rich, aromatic cream sauce', price: '$15.99' },
    { name: 'Paneer Tikka Masala', description: 'Soft cottage cheese in a rich, spiced cream sauce', price: '$14.99' },
    { name: 'Lamb Rogan Josh', description: 'Tender lamb pieces in a fragrant tomato-based curry', price: '$17.99' },
    { name: 'Biryani (Chicken)', description: 'Fragrant basmati rice layered with tender chicken and spices', price: '$16.99' },
    { name: 'Biryani (Lamb)', description: 'Aromatic rice with tender lamb and exotic spices', price: '$17.99' },
    { name: 'Vegetable Biryani', description: 'Mixed vegetables with fragrant rice and spices', price: '$13.99' },
    { name: 'Shrimp Curry', description: 'Fresh shrimp in a tangy and spiced coconut curry', price: '$16.99' },
    { name: 'Chana Masala', description: 'Chickpeas in a fragrant tomato and onion sauce', price: '$12.99' },
    { name: 'Dal Makhani', description: 'Creamed lentils with butter and aromatic spices', price: '$11.99' },
  ],
  breads: [
    { name: 'Naan', description: 'Traditional Indian flatbread baked in a tandoor oven', price: '$3.99' },
    { name: 'Garlic Naan', description: 'Naan bread brushed with garlic and cilantro', price: '$4.99' },
    { name: 'Peshwari Naan', description: 'Naan filled with coconut and dried fruits', price: '$5.99' },
    { name: 'Roti', description: 'Whole wheat flatbread', price: '$2.99' },
    { name: 'Paratha', description: 'Flaky layered bread with ghee', price: '$4.99' },
    { name: 'Bhatura', description: 'Fluffy fried bread, perfect for dipping', price: '$3.99' },
  ],
  desserts: [
    { name: 'Gulab Jamun', description: 'Soft milk solids in a light sugar syrup', price: '$4.99' },
    { name: 'Kheer', description: 'Rice pudding with milk, cardamom, and nuts', price: '$4.99' },
    { name: 'Mango Lassi', description: 'Creamy yogurt drink with fresh mango', price: '$3.99' },
    { name: 'Ras Malai', description: 'Soft cheese balls in sweetened cream', price: '$5.99' },
  ],
  beverages: [
    { name: 'Mango Lassi', description: 'Sweet yogurt drink with fresh mango', price: '$3.99' },
    { name: 'Sweet Lassi', description: 'Traditional sweetened yogurt beverage', price: '$2.99' },
    { name: 'Chai', description: 'Warm Indian tea with aromatic spices', price: '$2.99' },
    { name: 'Masala Chai', description: 'Spiced Indian tea with cardamom and ginger', price: '$3.99' },
    { name: 'Mango Juice', description: 'Fresh mango juice', price: '$2.99' },
    { name: 'Bottled Water', description: '', price: '$1.99' },
  ],
};
---

<Layout title="Menu" description="View the menu at Flavors of India - Authentic Indian Restaurant">
  <!-- Header -->
  <section class="bg-gradient-to-r from-deep-red to-saffron text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-bold font-serif mb-3">Our Menu</h1>
      <p class="text-lg">Authentic Indian dishes prepared with traditional recipes and fresh ingredients</p>
    </div>
  </section>

  <!-- Menu Content -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Appetizers -->
    <section class="mb-16">
      <h2 class="text-4xl font-bold font-serif text-navy mb-8 pb-4 border-b-4 border-saffron">Appetizers</h2>
      <div class="grid gap-6">
        {menu.appetizers.map((item) => (
          <div class="bg-cream p-6 rounded-lg hover:shadow-lg transition">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-xl font-bold text-navy font-serif mb-2">{item.name}</h3>
                <p class="text-gray-600">{item.description}</p>
              </div>
              <p class="text-saffron font-bold text-lg ml-4 whitespace-nowrap">{item.price}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Main Courses -->
    <section class="mb-16">
      <h2 class="text-4xl font-bold font-serif text-navy mb-8 pb-4 border-b-4 border-saffron">Main Courses</h2>
      <div class="grid gap-6">
        {menu.mainCourses.map((item) => (
          <div class="bg-cream p-6 rounded-lg hover:shadow-lg transition">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-xl font-bold text-navy font-serif mb-2">{item.name}</h3>
                <p class="text-gray-600">{item.description}</p>
              </div>
              <p class="text-saffron font-bold text-lg ml-4 whitespace-nowrap">{item.price}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Breads -->
    <section class="mb-16">
      <h2 class="text-4xl font-bold font-serif text-navy mb-8 pb-4 border-b-4 border-saffron">Breads</h2>
      <div class="grid gap-6">
        {menu.breads.map((item) => (
          <div class="bg-cream p-6 rounded-lg hover:shadow-lg transition">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-xl font-bold text-navy font-serif mb-2">{item.name}</h3>
                <p class="text-gray-600">{item.description}</p>
              </div>
              <p class="text-saffron font-bold text-lg ml-4 whitespace-nowrap">{item.price}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Desserts -->
    <section class="mb-16">
      <h2 class="text-4xl font-bold font-serif text-navy mb-8 pb-4 border-b-4 border-saffron">Desserts</h2>
      <div class="grid gap-6">
        {menu.desserts.map((item) => (
          <div class="bg-cream p-6 rounded-lg hover:shadow-lg transition">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-xl font-bold text-navy font-serif mb-2">{item.name}</h3>
                <p class="text-gray-600">{item.description}</p>
              </div>
              <p class="text-saffron font-bold text-lg ml-4 whitespace-nowrap">{item.price}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Beverages -->
    <section>
      <h2 class="text-4xl font-bold font-serif text-navy mb-8 pb-4 border-b-4 border-saffron">Beverages</h2>
      <div class="grid gap-6">
        {menu.beverages.map((item) => (
          <div class="bg-cream p-6 rounded-lg hover:shadow-lg transition">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-xl font-bold text-navy font-serif mb-2">{item.name}</h3>
                {item.description && <p class="text-gray-600">{item.description}</p>}
              </div>
              <p class="text-saffron font-bold text-lg ml-4 whitespace-nowrap">{item.price}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-navy to-deep-red text-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold font-serif mb-4">See something you like?</h2>
      <p class="text-lg mb-8">Call us or visit us today to enjoy these delicious dishes!</p>
      <a href="/contact" class="bg-saffron hover:bg-orange-600 text-navy px-8 py-3 rounded-lg font-semibold transition inline-block">
        Reserve a Table
      </a>
    </div>
  </section>
</Layout>
