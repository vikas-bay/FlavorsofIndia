---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Flavors of India - Authentic Indian Restaurant in Houston">
  <!-- Header -->
  <section class="bg-gradient-to-r from-deep-red to-saffron text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-bold font-serif mb-3">Contact Us</h1>
      <p class="text-lg">We'd love to hear from you</p>
    </div>
  </section>

  <!-- Contact Content -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact Information -->
      <div>
        <h2 class="text-3xl font-bold font-serif text-navy mb-8">Get in Touch</h2>

        <div class="space-y-8">
          <!-- Address -->
          <div class="flex gap-4">
            <div class="text-3xl">📍</div>
            <div>
              <h3 class="text-xl font-bold font-serif text-navy mb-2">Address</h3>
              <p class="text-gray-600">Houston, Texas</p>
              <p class="text-gray-600">United States</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex gap-4">
            <div class="text-3xl">📞</div>
            <div>
              <h3 class="text-xl font-bold font-serif text-navy mb-2">Phone</h3>
              <a href="tel:+17135551234" class="text-saffron hover:text-deep-red font-semibold">
                (713) 555-1234
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex gap-4">
            <div class="text-3xl">✉️</div>
            <div>
              <h3 class="text-xl font-bold font-serif text-navy mb-2">Email</h3>
              <a href="mailto:info@flavorsofindia.com" class="text-saffron hover:text-deep-red font-semibold">
                info@flavorsofindia.com
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex gap-4">
            <div class="text-3xl">🕐</div>
            <div>
              <h3 class="text-xl font-bold font-serif text-navy mb-2">Hours</h3>
              <p class="text-gray-600"><strong>Lunch:</strong> 11:00 AM - 2:30 PM</p>
              <p class="text-gray-600"><strong>Dinner:</strong> 5:00 PM - 10:00 PM</p>
              <p class="text-gray-600"><strong>Closed:</strong> Mondays</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <h2 class="text-3xl font-bold font-serif text-navy mb-8">Send us a Message</h2>

        <form id="contactForm" class="space-y-6">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-navy mb-2">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-saffron focus:outline-none"
              placeholder="Your full name"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-navy mb-2">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-saffron focus:outline-none"
              placeholder="your.email@example.com"
            />
          </div>

          <!-- Phone -->
          <div>
            <label for="phone" class="block text-sm font-semibold text-navy mb-2">Phone</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-saffron focus:outline-none"
              placeholder="(713) 555-1234"
            />
          </div>

          <!-- Subject -->
          <div>
            <label for="subject" class="block text-sm font-semibold text-navy mb-2">Subject *</label>
            <select
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-saffron focus:outline-none"
            >
              <option value="">Select a subject</option>
              <option value="reservation">Restaurant Reservation</option>
              <option value="catering">Catering Inquiry</option>
              <option value="feedback">Feedback</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-semibold text-navy mb-2">Message *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-saffron focus:outline-none"
              placeholder="Tell us more about your inquiry..."
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-deep-red to-saffron text-white font-bold py-3 rounded-lg hover:shadow-lg transition"
          >
            Send Message
          </button>

          <!-- Success Message -->
          <div id="successMessage" class="hidden bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded">
            <p class="font-semibold">Thank you for your message!</p>
            <p>We'll get back to you as soon as possible.</p>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Map Section (Placeholder) -->
  <section class="bg-gray-100 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold font-serif text-navy text-center mb-8">Find Us</h2>
      <div class="bg-gray-300 rounded-lg h-96 flex items-center justify-center">
        <div class="text-center">
          <div class="text-6xl mb-4">📍</div>
          <p class="text-gray-700 text-lg">Map location coming soon</p>
          <p class="text-gray-600">Houston, Texas</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contactForm');
  const successMessage = document.getElementById('successMessage');

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Clear form
      form.reset();

      // Show success message
      successMessage.classList.remove('hidden');

      // Hide success message after 5 seconds
      setTimeout(() => {
        successMessage.classList.add('hidden');
      }, 5000);

      // Scroll to success message
      successMessage.scrollIntoView({ behavior: 'smooth' });
    });
  }
</script>
